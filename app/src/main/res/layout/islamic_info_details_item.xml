<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardDua"
    android:layout_width="match_parent"
    android:layout_margin="5dp"
    android:layout_height="wrap_content"
    android:elevation="10dp"
    app:cardCornerRadius="10dp">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/bg_dark_grey_stroke_gradient"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/llTitle"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <!-- TITLE -->
            <ImageView
                android:id="@+id/ivPattern"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/pattern"
                app:layout_constraintBottom_toBottomOf="@id/tvName"
                app:layout_constraintTop_toTopOf="@id/tvName" />

            <!-- TITLE -->
            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/googlesans_bold"
                android:text="What is Islam?"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivPattern"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.5" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRakat"
                android:textSize="16sp"
                app:layout_constraintStart_toEndOf="@id/ivPattern"
                android:text=""
                android:fontFamily="@font/googlesans_medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/tvTiming"
                android:textSize="16sp"
                app:layout_constraintStart_toEndOf="@id/ivPattern"
                android:text=""
                android:fontFamily="@font/googlesans_medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvDetails"
                android:textSize="16sp"
                app:layout_constraintStart_toEndOf="@id/ivPattern"
                android:text=""
                android:fontFamily="@font/googlesans_medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>



        </LinearLayout>


    </LinearLayout>

</androidx.cardview.widget.CardView>