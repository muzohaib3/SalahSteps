<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/white_rounded_bg"
    android:padding="32dp">

    <!-- Top Decorative Line -->
    <View
        android:id="@+id/decorativeLine"
        android:layout_width="60dp"
        android:layout_height="4dp"
        android:background="@drawable/rounded_corners"
        android:backgroundTint="@color/green_009"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Image Container with Animated Gradient -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardImage"
        android:layout_width="280dp"
        android:layout_height="280dp"
        app:cardCornerRadius="25dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/decorativeLine"
        app:layout_constraintBottom_toTopOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginTop="24dp"
        android:translationZ="8dp">

        <!-- Animated Gradient Background -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/gradient_bg_qibla"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivOnboarding"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:contentDescription="@string/app_name"
                android:tint="@color/green_009"
                android:src="@drawable/qibla"
                android:scaleType="centerInside"
                android:rotation="0" />
        </LinearLayout>

        <!-- Top Shine -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/white"
            android:alpha="0.4"
            android:layout_gravity="top" />

    </androidx.cardview.widget.CardView>

    <!-- Compass Ring Decoration (Optional) -->
    <FrameLayout
        android:layout_width="300dp"
        android:layout_height="300dp"
        app:layout_constraintTop_toBottomOf="@id/decorativeLine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/compass_ring"
            android:alpha="0.1" />

    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Find Qibla Direction"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="@color/green_009"
        android:textAlignment="center"
        android:layout_marginTop="48dp"
        android:letterSpacing="0.05"
        app:layout_constraintTop_toBottomOf="@id/cardImage"
        app:layout_constraintBottom_toTopOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Decorative Divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="50dp"
        android:layout_height="3dp"
        android:background="@color/green_009"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvDescription" />

    <!-- Description with Urdu Text -->
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="کعبہ کی سمت معلوم کریں دنیا میں کہیں بھی"
        android:textSize="16sp"
        android:textColor="@color/green_009"
        android:alpha="0.8"
        android:textAlignment="center"
        android:layout_marginTop="24dp"
        android:lineSpacingExtra="4dp"
        android:letterSpacing="0.02"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Animated Dot Indicators -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_inactive"
            android:backgroundTint="@color/green_009"
            android:alpha="0.3"
            android:layout_margin="4dp" />

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_active"
            android:backgroundTint="@color/green_009"
            android:layout_margin="4dp" />

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_inactive"
            android:backgroundTint="@color/green_009"
            android:alpha="0.3"
            android:layout_margin="4dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>